[Unit]
Description=RF Site Telemetry Cloud API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/rfsite/cloud-api

# Use config file instead of env file
Environment=CONFIG_FILE=/etc/rfsite/cloud-api.yaml

# Optional: fallback env file for additional overrides
EnvironmentFile=-/etc/rfsite/cloud-api.env

# Ajustá path al venv real
ExecStart=/opt/rfsite/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001

Restart=always
RestartSec=2

# hardening razonable
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/rfsite /tmp /var/log/rfsite

[Install]
WantedBy=multi-user.target
