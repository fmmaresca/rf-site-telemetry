# RF Site Telemetry Cloud API Environment Variables
# These override settings from the config file

# Primary config file location
CONFIG_FILE=/etc/rfsite/cloud-api.yaml

# Database (overrides config file if set)
# DB_DSN=postgresql://rftelemetry:rftelemetry@127.0.0.1:5432/rftelemetry

# Authentication (overrides config file if set)
# AUTH_REQUIRED=1
# PUBLIC_READONLY_TENANT=demo

# Logging (overrides config file if set)
# LOGGING__LEVEL=INFO
# LOGGING__FILE_PATH=/var/log/rfsite/cloud-api.log
